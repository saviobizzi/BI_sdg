rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ╔══════════════════════════════════════════════════════════╗
    // ║  BI Sondagem — Energold — Firestore Security Rules      ║
    // ║  Controle de acesso por membro e criador                ║
    // ╚══════════════════════════════════════════════════════════╝
    // ── Helpers de autenticação ──
    function signedIn() {
      return request.auth != null;
    }
    function userEmail() {
      return request.auth.token.email != null ? request.auth.token.email : '';
    }
    function userUid() {
      return request.auth.uid;
    }
    // ── Validação de membros ──
    function memberListExists(data) {
      return data.members is list;
    }
    function creatorMatches(data) {
      return data.createdBy == userEmail() || data.createdBy == userUid();
    }
    function memberMatches(data) {
      return signedIn() && (
        (
          memberListExists(data) &&
          (userEmail() in data.members || userUid() in data.members)
        )
        || creatorMatches(data)
      );
    }
    function legacyCreatorBlank(data) {
      return !(data.keys().hasAny(['createdBy']))
        || data.createdBy == null
        || data.createdBy == '';
    }
    // ── Referência ao documento do projeto (para subcollections) ──
    function projectData(projectId) {
      return get(/databases/$(database)/documents/projects/$(projectId)).data;
    }
    function canAccessProject(projectId) {
      return signedIn() && memberMatches(projectData(projectId));
    }
    // ── Validação de campos obrigatórios ──
    function hasRequiredProjectFields(data) {
      return data.keys().hasAll([
        'name',
        'cliente',
        'local',
        'createdBy',
        'createdAt',
        'members'
      ]);
    }
    function hasExpectedProjectTypes(data) {
      return data.name is string
        && data.cliente is string
        && data.local is string
        && data.createdBy is string
        && data.createdAt is string
        && data.members is list;
    }
    function memberListSafe(data) {
      return memberListExists(data)
        && data.members.size() > 0
        && data.members.size() <= 120
        && (userEmail() in data.members || userUid() in data.members);
    }
    // ── Campos imutáveis após criação ──
    function immutableCoreFieldsPreserved() {
      return request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.createdAt == resource.data.createdAt;
    }
    // ── Validação de status ──
    function validStatus(value) {
      return value in [
        'aguardando', 'aprovada', 'reprovada',
        'pendente', 'em-analise', 'resolvido',
        'aberto', 'concluida', 'faturado', 'recebido'
      ];
    }
    // ── Limite de tamanho do documento (segurança contra abuso) ──
    function documentSizeOk() {
      return request.resource.size() < 900000;
    }
    // ════════════════════════════════════
    //   PROJETOS
    // ════════════════════════════════════
    match /projects/{projectId} {
      // Leitura: autenticado + membro do projeto
      allow get, list: if signedIn()
        && memberMatches(resource.data);
      // Criação: autenticado + campos obrigatórios + tipos corretos +
      //          criador é o usuário + lista de membros segura
      allow create: if signedIn()
        && hasRequiredProjectFields(request.resource.data)
        && hasExpectedProjectTypes(request.resource.data)
        && creatorMatches(request.resource.data)
        && memberListSafe(request.resource.data)
        && documentSizeOk();
      // Atualização: autenticado + membro + campos imutáveis preservados +
      //              campos obrigatórios + tipos corretos + lista de membros segura
      allow update: if signedIn()
        && memberMatches(resource.data)
        && immutableCoreFieldsPreserved()
        && hasRequiredProjectFields(request.resource.data)
        && hasExpectedProjectTypes(request.resource.data)
        && memberListSafe(request.resource.data)
        && documentSizeOk()
        && (
          !(request.resource.data.keys().hasAny(['status']))
          || validStatus(request.resource.data.status)
        );
      // Exclusão: autenticado + criador OU (criador em branco + membro)
      allow delete: if signedIn()
        && (
          creatorMatches(resource.data)
          || (legacyCreatorBlank(resource.data) && memberMatches(resource.data))
        );
      // ════════════════════════════════════
      //   PRESENÇA (subcollection)
      // ════════════════════════════════════
      match /presence/{userId} {
        // Leitura: autenticado + membro do projeto-pai
        allow read: if signedIn()
          && canAccessProject(projectId);
        // Criação/atualização: autenticado + membro do projeto-pai +
        //                      userId corresponde ao auth.uid +
        //                      campos restritos + tipos corretos
        allow create, update: if signedIn()
          && canAccessProject(projectId)
          && userId == request.auth.uid
          && request.resource.data.keys().hasOnly(['uid', 'name', 'email', 'photoURL', 'lastSeen'])
          && request.resource.data.uid == request.auth.uid
          && request.resource.data.name is string
          && request.resource.data.name.size() <= 200
          && request.resource.data.email is string
          && request.resource.data.email.size() <= 320
          && request.resource.data.photoURL is string
          && request.resource.data.photoURL.size() <= 2048;
        // Exclusão: autenticado + membro do projeto-pai + próprio documento
        allow delete: if signedIn()
          && canAccessProject(projectId)
          && userId == request.auth.uid;
      }
    }
    // Bloqueia tudo o que não é explicitamente permitido
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
